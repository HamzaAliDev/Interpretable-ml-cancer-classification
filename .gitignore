# ------------------------------
# Python bytecode / cache
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------
# Virtual environments
# ------------------------------
venv/
.venv/
env/
ENV/

# ------------------------------
# Jupyter
# ------------------------------
.ipynb_checkpoints/

# ------------------------------
# Build / packaging artifacts
# ------------------------------
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/

# ------------------------------
# Test / coverage / type-check caches
# ------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# ------------------------------
# Logs
# ------------------------------
*.log
logs/

# ------------------------------
# Environment / secrets (never commit)
# ------------------------------
.env
.env.*
*.env
secrets/

# ------------------------------
# IDE / editor
# ------------------------------
.vscode/
.idea/

# ------------------------------
# OS-specific files
# ------------------------------
.DS_Store
Thumbs.db

